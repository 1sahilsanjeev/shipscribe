{
  "version": 2,
  "builds": [
    {
      "src": "shipscribe-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/health.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/assets/(.*)", "destination": "/shipscribe-dashboard/assets/$1" },
    { "source": "/", "destination": "/shipscribe-dashboard/index.html" },
    { "source": "/((?!api/|assets/).*)", "destination": "/shipscribe-dashboard/index.html" }
  ]
}
