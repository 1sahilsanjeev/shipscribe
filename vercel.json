{
  "version": 2,
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/((?!api/)[^.]*)", "destination": "/shipscribe-dashboard/dist/index.html" },
    { "source": "/(.*)", "destination": "/shipscribe-dashboard/dist/$1" }
  ]
}
