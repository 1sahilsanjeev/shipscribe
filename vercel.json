{
  "version": 2,
  "builds": [
    {
      "src": "shipscribe-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "src/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "shipscribe-dashboard/$1"
    }
  ]
}
