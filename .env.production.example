# Shipscribe Production Environment Configuration
# Copy this to .env in production and update values

# Database Connection (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/shipscribe

# Security
JWT_SECRET=generate-a-secure-32-character-random-string-here

# Integration Keys
ANTHROPIC_API_KEY=sk-ant-xxx...
GITHUB_TOKEN=ghp_xxx...

# Server Config
NODE_ENV=production
PORT=3001

# CORS - Allowed frontend origins (comma separated)
CORS_ORIGINS=https://shipscribe.dev,https://app.shipscribe.dev
